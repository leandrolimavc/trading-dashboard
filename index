<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Trading Dashboard 2026</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<!-- Firebase SDKs -->
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, collection, doc, setDoc, getDocs, query, where, orderBy }
  from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
import { getAuth, signInWithEmailAndPassword, signOut, onAuthStateChanged }
  from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

const firebaseConfig = {
  apiKey: "AIzaSyASFgxGVhBnM8kHF9xSgsbBd5K7LfM4Zdc",
  authDomain: "trading-2026-56ecc.firebaseapp.com",
  projectId: "trading-2026-56ecc",
  storageBucket: "trading-2026-56ecc.firebasestorage.app",
  messagingSenderId: "246053123968",
  appId: "1:246053123968:web:35bd66d3cd29d6e8633365"
};

const app  = initializeApp(firebaseConfig);
const db   = getFirestore(app);
const auth = getAuth(app);

const CAPITAL   = 500;
const MESES     = ["Mai","Jun","Jul","Ago","Set","Out","Nov","Dez"];
const MESES_NUM = [5,6,7,8,9,10,11,12];
const ANO       = 2026;

let currentUser = null;
let chartInstance = null;
let abaAtual = "dashboard";

// ── Helpers ──────────────────────────────────────────────
const $ = id => document.getElementById(id);
const fmtUSD  = v => `$${parseFloat(v||0).toFixed(2)}`;
const fmtPct  = v => `${parseFloat(v||0).toFixed(2)}%`;
const fmtSgn  = v => (v >= 0 ? "+" : "") + fmtUSD(v);
const fmtPctS = v => (v >= 0 ? "+" : "") + fmtPct(v);
const corCls  = v => parseFloat(v) >= 0 ? "pos" : "neg";

function toast(msg, tipo = "ok") {
  const el = $("toast");
  el.textContent = msg;
  el.className = `toast show ${tipo}`;
  setTimeout(() => el.className = "toast", 3000);
}

function loading(msg = "Carregando...") {
  $("main").innerHTML = `<div class="loading"><div class="spinner"></div>${msg}</div>`;
}

// ── Auth ─────────────────────────────────────────────────
onAuthStateChanged(auth, user => {
  currentUser = user;
  if (user) {
    $("login-screen").style.display = "none";
    $("app").style.display = "block";
    renderTabs();
    renderDashboard();
  } else {
    $("login-screen").style.display = "flex";
    $("app").style.display = "none";
  }
});

window.fazerLogin = async () => {
  const email = $("email").value.trim();
  const senha = $("senha").value;
  const btn   = $("btn-login");
  if (!email || !senha) { toast("Preencha e-mail e senha", "err"); return; }
  btn.disabled = true; btn.textContent = "Entrando...";
  try {
    await signInWithEmailAndPassword(auth, email, senha);
  } catch (e) {
    toast("E-mail ou senha incorretos", "err");
    btn.disabled = false; btn.textContent = "Entrar";
  }
};

window.fazerLogout = async () => {
  await signOut(auth);
};

$("senha") && $("senha").addEventListener("keydown", e => {
  if (e.key === "Enter") window.fazerLogin();
});

// ── Firestore ─────────────────────────────────────────────
async function salvarOperacao(mes, dia, resultado, obs) {
  const id = `${ANO}-${mes}-${String(dia).padStart(2,"0")}`;
  await setDoc(doc(db, "operacoes", id), {
    mes, dia, resultado: parseFloat(resultado), obs,
    ano: ANO, timestamp: new Date().toISOString()
  });
}

async function getOperacoesMes(mes) {
  const q = query(
    collection(db, "operacoes"),
    where("mes", "==", mes),
    where("ano", "==", ANO),
    orderBy("dia")
  );
  const snap = await getDocs(q);
  return snap.docs.map(d => d.data()).sort((a,b) => a.dia - b.dia);
}

async function getTodasOperacoes() {
  const q = query(
    collection(db, "operacoes"),
    where("ano", "==", ANO),
    orderBy("mes"), orderBy("dia")
  );
  const snap = await getDocs(q);
  return snap.docs.map(d => d.data());
}

// ── Cálculos ──────────────────────────────────────────────
function calcResumo(ops, capitalMes) {
  let saldo = capitalMes;
  let melhor = null, pior = null, pos = 0, neg = 0;
  const historico = [];

  ops.forEach(op => {
    saldo += op.resultado;
    if (op.resultado > 0) { pos++; if (melhor === null || op.resultado > melhor) melhor = op.resultado; }
    if (op.resultado < 0) { neg++; if (pior   === null || op.resultado < pior)   pior   = op.resultado; }
    historico.push({ dia: op.dia, resultado: op.resultado, saldo, obs: op.obs });
  });

  const totalRes = saldo - capitalMes;
  return {
    capitalMes, saldoFinal: saldo, resultado: totalRes,
    pct: (totalRes / capitalMes) * 100,
    melhor: melhor ? (melhor / capitalMes) * 100 : null,
    pior:   pior   ? (pior   / capitalMes) * 100 : null,
    pos, neg, historico
  };
}

// ── Tabs ─────────────────────────────────────────────────
function renderTabs() {
  const tabs = $("tabs");
  const itens = [{ id: "dashboard", label: "Dashboard" },
    ...MESES.map((m, i) => ({ id: m, label: m }))];
  tabs.innerHTML = itens.map(t =>
    `<div class="tab ${t.id === abaAtual ? "active" : ""}" onclick="trocarAba('${t.id}')">${t.label}</div>`
  ).join("");
}

window.trocarAba = id => {
  abaAtual = id;
  renderTabs();
  if (id === "dashboard") renderDashboard();
  else renderMes(id);
};

// ── Dashboard ─────────────────────────────────────────────
async function renderDashboard() {
  loading();
  const todas = await getTodasOperacoes();

  // Agrupar por mês
  const porMes = {};
  MESES.forEach(m => porMes[m] = []);
  todas.forEach(op => { if (porMes[op.mes]) porMes[op.mes].push(op); });

  // Calcular capital encadeado
  let cap = CAPITAL;
  const resumosMes = [];
  MESES.forEach(mes => {
    const ops = porMes[mes];
    const r = calcResumo(ops, cap);
    resumosMes.push({ mes, ...r });
    if (ops.length > 0) cap = r.saldoFinal;
  });

  const totalRes = resumosMes.reduce((s,r) => s + r.resultado, 0);
  const saldoAtual = CAPITAL + totalRes;
  const pctTotal = (totalRes / CAPITAL) * 100;
  const totalPos = resumosMes.reduce((s,r) => s + r.pos, 0);
  const totalNeg = resumosMes.reduce((s,r) => s + r.neg, 0);

  $("main").innerHTML = `
    <div class="cards-grid">
      <div class="card card-full">
        <div class="card-label">Saldo Atual</div>
        <div class="card-value ${corCls(totalRes)}">${fmtUSD(saldoAtual)}</div>
        <div class="card-sub">Capital inicial: ${fmtUSD(CAPITAL)}</div>
      </div>
      <div class="card">
        <div class="card-label">Resultado Total</div>
        <div class="card-value ${corCls(totalRes)}" style="font-size:18px">${fmtSgn(totalRes)}</div>
      </div>
      <div class="card">
        <div class="card-label">Rentabilidade</div>
        <div class="card-value ${corCls(pctTotal)}" style="font-size:18px">${fmtPctS(pctTotal)}</div>
      </div>
      <div class="card">
        <div class="card-label">Dias Positivos</div>
        <div class="card-value pos" style="font-size:20px">${totalPos}</div>
      </div>
      <div class="card">
        <div class="card-label">Dias Negativos</div>
        <div class="card-value neg" style="font-size:20px">${totalNeg}</div>
      </div>
    </div>

    <div class="chart-wrap">
      <div class="chart-title">Resultado por Mês</div>
      <canvas id="chartDash" height="160"></canvas>
    </div>

    <div class="hist-card">
      <div class="hist-header">Resumo Mensal</div>
      ${resumosMes.map(r => `
        <div class="mes-row" onclick="trocarAba('${r.mes}')">
          <div class="mes-nome">${r.mes}</div>
          <div class="mes-cap" style="color:var(--muted);font-size:11px">${fmtUSD(r.capitalMes)}</div>
          <div class="mes-res ${corCls(r.resultado)}">${fmtSgn(r.resultado)}</div>
          <div class="mes-pct ${corCls(r.pct)}">${fmtPctS(r.pct)}</div>
          <div style="font-size:11px;color:var(--muted)">${r.pos}✓ ${r.neg}✗</div>
        </div>
      `).join("")}
    </div>
  `;

  renderChart("chartDash",
    resumosMes.map(r => r.mes),
    resumosMes.map(r => r.resultado),
    "Resultado ($)", true
  );
}

// ── Mês ──────────────────────────────────────────────────
async function renderMes(mes) {
  loading();
  const mesIdx  = MESES.indexOf(mes);
  const mnum    = MESES_NUM[mesIdx];
  const daysInM = new Date(ANO, mnum, 0).getDate();

  // Capital encadeado: somar resultado de meses anteriores
  const todas = await getTodasOperacoes();
  const porMes = {};
  MESES.forEach(m => porMes[m] = []);
  todas.forEach(op => { if (porMes[op.mes]) porMes[op.mes].push(op); });

  let capMes = CAPITAL;
  for (let i = 0; i < mesIdx; i++) {
    const r = calcResumo(porMes[MESES[i]], capMes);
    if (porMes[MESES[i]].length > 0) capMes = r.saldoFinal;
  }

  const ops = porMes[mes];
  const r   = calcResumo(ops, capMes);

  // Dias select
  let opsDias = "";
  for (let i = 1; i <= daysInM; i++)
    opsDias += `<option value="${i}">${String(i).padStart(2,"0")}</option>`;

  $("main").innerHTML = `
    <div class="cards-grid">
      <div class="card card-full">
        <div class="card-label">Saldo do Mês</div>
        <div class="card-value ${corCls(r.resultado)}">${fmtUSD(r.saldoFinal)}</div>
        <div class="card-sub">Capital: ${fmtUSD(capMes)} · ${fmtSgn(r.resultado)} (${fmtPctS(r.pct)})</div>
      </div>
      <div class="card">
        <div class="card-label">Média Diária</div>
        <div class="card-value ${corCls(r.resultado)} " style="font-size:16px">
          ${r.historico.length ? fmtSgn(r.resultado / r.historico.filter(h=>h.resultado!==0).length||1) : "-"}
        </div>
      </div>
      <div class="card">
        <div class="card-label">Dias +/-</div>
        <div class="card-value" style="font-size:16px;color:var(--blue)">${r.pos}✓ ${r.neg}✗</div>
      </div>
      <div class="card">
        <div class="card-label">Melhor Dia</div>
        <div class="card-value pos" style="font-size:14px">${r.melhor !== null ? fmtPctS(r.melhor) : "-"}</div>
      </div>
      <div class="card">
        <div class="card-label">Pior Dia</div>
        <div class="card-value neg" style="font-size:14px">${r.pior !== null ? fmtPctS(r.pior) : "-"}</div>
      </div>
    </div>

    ${r.historico.length ? `
    <div class="chart-wrap">
      <div class="chart-title">Evolução do Saldo — ${mes}</div>
      <canvas id="chartMes" height="150"></canvas>
    </div>` : ""}

    <div class="lancar-card">
      <div class="lancar-title"><i>⚡</i> Lançar Resultado</div>
      <div class="form-row">
        <label class="form-label">Dia</label>
        <select class="form-input" id="inp-dia">${opsDias}</select>
      </div>
      <div class="form-row">
        <label class="form-label">Resultado (USD) · use − para perda</label>
        <input class="form-input" id="inp-valor" type="number" step="0.01" placeholder="Ex: 12.50 ou -5.00">
      </div>
      <div class="form-row">
        <label class="form-label">Observação (opcional)</label>
        <input class="form-input" id="inp-obs" type="text" placeholder="Ex: 1 trade, stop ativado">
      </div>
      <button class="btn-primary" id="btn-lancar" onclick="lancar('${mes}')">Registrar</button>
    </div>

    ${r.historico.length ? `
    <div class="hist-card">
      <div class="hist-header">Histórico</div>
      ${r.historico.slice().reverse().map(h => `
        <div class="hist-row">
          <div class="hist-dia">Dia ${h.dia}</div>
          <div class="hist-res ${corCls(h.resultado)}">${fmtSgn(h.resultado)}</div>
          <div class="hist-saldo">${fmtUSD(h.saldo)}</div>
          <div class="hist-obs">${h.obs || ""}</div>
        </div>
      `).join("")}
    </div>` : `<div class="loading" style="padding:16px;font-size:12px">Sem lançamentos ainda</div>`}
  `;

  if (r.historico.length) {
    renderChart("chartMes",
      r.historico.map(h => `Dia ${h.dia}`),
      r.historico.map(h => parseFloat(h.saldo.toFixed(2))),
      "Saldo ($)", false
    );
  }
}

// ── Chart ─────────────────────────────────────────────────
function renderChart(id, labels, data, label, isBar) {
  if (chartInstance) { chartInstance.destroy(); chartInstance = null; }
  const ctx = $(id);
  if (!ctx) return;
  const pos = data[data.length - 1] >= 0;
  chartInstance = new Chart(ctx, {
    type: isBar ? "bar" : "line",
    data: {
      labels,
      datasets: [{
        label,
        data,
        borderColor: "#00d97e",
        backgroundColor: isBar
          ? data.map(v => v >= 0 ? "rgba(0,217,126,.75)" : "rgba(255,77,106,.75)")
          : "transparent",
        borderWidth: 2,
        pointRadius: 3,
        pointBackgroundColor: "#f0b429",
        tension: 0.35
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: c => `$${c.parsed.y.toFixed(2)}` } }
      },
      scales: {
        x: { ticks: { color: "#5a6f8a", font: { size: 10 } }, grid: { color: "#1e2d4a" } },
        y: { ticks: { color: "#5a6f8a", font: { size: 10 }, callback: v => `$${v.toFixed(0)}` }, grid: { color: "#1e2d4a" } }
      }
    }
  });
}

// ── Lançar ────────────────────────────────────────────────
window.lancar = async mes => {
  const dia    = parseInt($("inp-dia").value);
  const valor  = parseFloat($("inp-valor").value);
  const obs    = ($("inp-obs").value || "").trim();
  if (isNaN(valor)) { toast("Digite um valor válido", "err"); return; }
  const btn = $("btn-lancar");
  btn.disabled = true; btn.textContent = "Salvando...";
  try {
    await salvarOperacao(mes, dia, valor, obs);
    toast(`Dia ${dia} registrado: ${fmtSgn(valor)}`);
    renderMes(mes);
  } catch(e) {
    toast("Erro ao salvar: " + e.message, "err");
    btn.disabled = false; btn.textContent = "Registrar";
  }
};
</script>

<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#090e1a;--surface:#0f1726;--surface2:#151f33;
  --border:#1e2d4a;--gold:#f0b429;--green:#00d97e;
  --red:#ff4d6a;--blue:#4da6ff;--text:#e8edf5;--muted:#5a6f8a;
}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;min-height:100vh;overflow-x:hidden;}

/* Login */
#login-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px;}
.login-box{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:32px 24px;width:100%;max-width:340px;}
.login-logo{font-size:22px;font-weight:700;color:var(--gold);letter-spacing:-1px;margin-bottom:6px;}
.login-logo span{color:var(--text);font-weight:400;}
.login-sub{font-size:12px;color:var(--muted);margin-bottom:24px;}
.login-label{font-size:11px;color:var(--muted);font-family:'JetBrains Mono',monospace;letter-spacing:.06em;text-transform:uppercase;margin-bottom:5px;display:block;}
.login-input{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-size:14px;outline:none;margin-bottom:14px;font-family:'Inter',sans-serif;}
.login-input:focus{border-color:var(--gold);}
.login-btn{width:100%;background:var(--gold);color:#000;border:none;border-radius:8px;padding:12px;font-family:'Inter',sans-serif;font-size:14px;font-weight:700;cursor:pointer;}
.login-btn:hover{opacity:.85;}
.login-btn:disabled{opacity:.4;cursor:not-allowed;}

/* App */
#app{display:none;}
.header{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-bottom:1px solid var(--border);background:var(--surface);position:sticky;top:0;z-index:100;}
.logo{font-size:17px;font-weight:700;color:var(--gold);letter-spacing:-0.5px;}
.logo span{color:var(--text);font-weight:400;}
.logout-btn{background:transparent;border:1px solid var(--border);border-radius:6px;padding:5px 10px;color:var(--muted);font-size:11px;cursor:pointer;font-family:'JetBrains Mono',monospace;}
.logout-btn:hover{color:var(--red);border-color:var(--red);}
.badge-live{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--green);font-family:'JetBrains Mono',monospace;}
.dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}

.tabs{display:flex;gap:4px;padding:10px 12px;overflow-x:auto;background:var(--surface);border-bottom:1px solid var(--border);}
.tabs::-webkit-scrollbar{display:none;}
.tab{padding:5px 12px;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap;border:1px solid transparent;color:var(--muted);transition:all .15s;}
.tab.active{background:var(--gold);color:#000;border-color:var(--gold);}
.tab:hover:not(.active){color:var(--text);border-color:var(--border);}

.main{padding:14px;max-width:560px;margin:0 auto;}
.cards-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:14px;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:13px;}
.card-full{grid-column:1/-1;}
.card-label{font-size:10px;color:var(--muted);font-family:'JetBrains Mono',monospace;letter-spacing:.08em;text-transform:uppercase;margin-bottom:5px;}
.card-value{font-size:21px;font-weight:700;font-family:'JetBrains Mono',monospace;letter-spacing:-1px;}
.card-value.pos{color:var(--green);}
.card-value.neg{color:var(--red);}
.card-sub{font-size:11px;color:var(--muted);margin-top:3px;font-family:'JetBrains Mono',monospace;}

.chart-wrap{background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:14px;margin-bottom:14px;}
.chart-title{font-size:11px;color:var(--muted);font-family:'JetBrains Mono',monospace;margin-bottom:10px;letter-spacing:.06em;text-transform:uppercase;}

.lancar-card{background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:14px;margin-bottom:14px;}
.lancar-title{font-size:13px;font-weight:700;color:var(--gold);margin-bottom:13px;}
.form-row{margin-bottom:11px;}
.form-label{font-size:10px;color:var(--muted);font-family:'JetBrains Mono',monospace;letter-spacing:.08em;text-transform:uppercase;margin-bottom:4px;display:block;}
.form-input{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:7px;padding:9px 11px;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:13px;outline:none;-webkit-appearance:none;}
.form-input:focus{border-color:var(--gold);}
.btn-primary{width:100%;background:var(--gold);color:#000;border:none;border-radius:7px;padding:12px;font-family:'Inter',sans-serif;font-size:14px;font-weight:700;cursor:pointer;}
.btn-primary:disabled{opacity:.4;cursor:not-allowed;}

.hist-card{background:var(--surface);border:1px solid var(--border);border-radius:11px;overflow:hidden;margin-bottom:14px;}
.hist-header{padding:10px 14px;border-bottom:1px solid var(--border);font-size:10px;color:var(--muted);font-family:'JetBrains Mono',monospace;letter-spacing:.08em;text-transform:uppercase;}
.hist-row{display:flex;align-items:center;justify-content:space-between;padding:9px 14px;border-bottom:1px solid var(--border);gap:6px;}
.hist-row:last-child{border-bottom:none;}
.hist-dia{color:var(--muted);font-size:11px;min-width:46px;font-family:'JetBrains Mono',monospace;}
.hist-res{font-weight:600;font-family:'JetBrains Mono',monospace;font-size:13px;}
.hist-res.pos{color:var(--green);}
.hist-res.neg{color:var(--red);}
.hist-saldo{color:var(--blue);font-size:12px;font-family:'JetBrains Mono',monospace;}
.hist-obs{color:var(--muted);font-size:11px;text-align:right;max-width:110px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}

.mes-row{display:flex;align-items:center;justify-content:space-between;padding:9px 14px;border-bottom:1px solid var(--border);cursor:pointer;gap:6px;}
.mes-row:last-child{border-bottom:none;}
.mes-row:hover{background:var(--surface2);}
.mes-nome{font-weight:700;font-size:13px;min-width:34px;}
.mes-res,.mes-pct{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;}
.mes-res.pos,.mes-pct.pos{color:var(--green);}
.mes-res.neg,.mes-pct.neg{color:var(--red);}

.loading{display:flex;align-items:center;justify-content:center;padding:40px;color:var(--muted);font-size:13px;gap:10px;font-family:'JetBrains Mono',monospace;}
.spinner{width:15px;height:15px;border:2px solid var(--border);border-top-color:var(--gold);border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:var(--surface2);border:1px solid var(--border);border-radius:9px;padding:11px 18px;font-size:13px;font-family:'JetBrains Mono',monospace;z-index:999;display:none;white-space:nowrap;}
.toast.show{display:block;animation:fadeup .25s ease;}
.toast.ok{border-color:var(--green);color:var(--green);}
.toast.err{border-color:var(--red);color:var(--red);}
@keyframes fadeup{from{opacity:0;transform:translateX(-50%) translateY(8px);}to{opacity:1;transform:translateX(-50%) translateY(0);}}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">TRADE<span>TRACK</span></div>
    <div class="login-sub">Diário de Trading 2026</div>
    <label class="login-label">E-mail</label>
    <input class="login-input" id="email" type="email" placeholder="seu@email.com" autocomplete="email">
    <label class="login-label">Senha</label>
    <input class="login-input" id="senha" type="password" placeholder="••••••••" autocomplete="current-password">
    <button class="login-btn" id="btn-login" onclick="fazerLogin()">Entrar</button>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="header">
    <div class="logo">TRADE<span>TRACK</span></div>
    <div style="display:flex;align-items:center;gap:10px;">
      <div class="badge-live"><div class="dot"></div>LIVE</div>
      <button class="logout-btn" onclick="fazerLogout()">Sair</button>
    </div>
  </div>
  <div class="tabs" id="tabs"></div>
  <div class="main" id="main">
    <div class="loading"><div class="spinner"></div>Carregando...</div>
  </div>
</div>

<div class="toast" id="toast"></div>
</body>
</html>
